# Max time (seconds) /api/pdm-extrato gives itself before returning 504.
# Defaults to 300 if unset. This is separate from the route's platform-level
# `maxDuration = 1800` (app/api/pdm-extrato/route.ts), which Next.js reads
# statically at build time and so can't be env-driven.
PDM_EXTRATO_MAX_DURATION=300
